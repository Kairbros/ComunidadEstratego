PORT=3001

# Secreto para firmar los JWT. Genera uno único y secreto, por ejemplo:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_SECRET=cambia-esto-por-un-secreto-largo-y-aleatorio

# URL pública del backend (prefijo de download_url de los PDFs subidos)
BASE_URL=https://api.comunidad.estratego.us

# Origen permitido por CORS (frontend)
FRONTEND_URL=https://comunidad.estratego.us

# Credenciales del admin inicial — solo se usan al sembrar la base de datos
ADMIN_USERNAME=EstrategoAdmin
ADMIN_PASSWORD=cambia-esta-contraseña

# GoHighLevel — captura de leads antes de cada descarga
# Token de integración privada (Private Integration Token, empieza con "pit-")
GHL_API_TOKEN=pit-xxxxxxxx
GHL_LOCATION_ID=tu-location-id
GHL_API_VERSION=2021-07-28
GHL_TAG=comunidad
